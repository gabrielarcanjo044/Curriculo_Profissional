# Copie este arquivo e renomeie para: .env

# Chave da API do Claude (Anthropic)
ANTHROPIC_API_KEY=sua-chave-aqui

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque-por-uma-string-secreta-longa

# Segredo para validar o webhook da InfinitePay (use uma string aleatória)
WEBHOOK_SECRET=troque-por-outro-segredo-aleatorio

# URL pública da aplicação (sem barra no final)
BASE_URL=https://curriculos.geminirecords.com.br

# Caminho do banco de dados SQLite
DB_PATH=/app/data/data.db

# Código de acesso empresarial (Infor 02 — gerações ilimitadas, sem cadastro)
COMPANY_CODE=troque-por-um-codigo-secreto
